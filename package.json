{
  "name": "homebridge-git-backup",
  "version": "2.0.0",
  "description": "Homebridge plugin to back up configs to any git repository via HTTPS (PAT) or SSH deployment key",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "github",
    "gitlab",
    "gitea",
    "forgejo",
    "homebridge",
    "homebridge-plugin",
    "backup",
    "home-automation"
  ],
  "engines": {
    "homebridge": ">=1.6.0",
    "node": ">=18.0.0"
  },
  "license": "ISC",
  "files": [
    "LICENSE",
    "dist",
    "config.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charlestephen/homebridge-git-backup.git"
  },
  "bugs": {
    "url": "https://github.com/charlestephen/homebridge-git-backup/issues"
  },
  "homepage": "https://github.com/charlestephen/homebridge-git-backup#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "homebridge": "^1.8.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "simple-git": "^3.27.0"
  }
}
